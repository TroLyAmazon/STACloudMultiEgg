    "name": "OpenClaw",
    "author": "congdongamazon@gmail.com",
    "uuid": "8a6c4e15-9c6b-4c7a-9d2e-3f7b2d9a6c51",
    "description": "Egg OpenClaw cho STACloud, chay OpenClaw Gateway trong Pterodactyl voi persistent state tai /home/container/.openclaw.",
    "features": null,
    "docker_images": {
        "OpenClaw Latest": "ghcr.io/sta-cloud-dev/ai:openclaw_latest"
    },
    "file_denylist": [],
    "startup": "openclaw gateway --allow-unconfigured --bind ${OPENCLAW_BIND} --port ${SERVER_PORT}",
    "config": {
        "files": "{}",
        "startup": "{\r\n    \"done\": \"listening on\"\r\n}",
        "logs": "{}",
        "stop": "^C"
    },
    "scripts": {
        "installation": {
            "script": "#!/bin/bash\r\nmkdir -p /mnt/server/.openclaw /mnt/server/.openclaw/workspace /mnt/server/.openclaw/skills\r\necho \"OpenClaw installation completed.\"",
            "container": "debian:bookworm-slim",
            "entrypoint": "bash"
        }
    },
    "variables": [
        {
            "name": "Gateway verbose",
            "description": "Enable verbose gateway logs. true = verbose, false = normal.",
            "env_variable": "OPENCLAW_VERBOSE",
            "default_value": "true",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string|in:true,false",
            "field_type": "text"
        },
        {
            "name": "Gateway bind",
            "description": "Listener bind mode for OpenClaw Gateway. Use 'lan' when behind a reverse proxy like Caddy/Nginx.",
            "env_variable": "OPENCLAW_BIND",
            "default_value": "lan",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string|in:loopback,lan,tailnet,auto,custom",
            "field_type": "text"
        },
        {
            "name": "Custom bind host",
            "description": "Required when Gateway bind is set to 'custom'. Enter the hostname or IP to bind to.",
            "env_variable": "OPENCLAW_CUSTOM_BIND_HOST",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "nullable|string|max:255",
            "field_type": "text"
        },
        {
            "name": "Gateway token",
            "description": "Token for clients connecting to the OpenClaw Gateway. Required when binding beyond loopback.",
            "env_variable": "OPENCLAW_GATEWAY_TOKEN",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "nullable|string|max:255",
            "field_type": "text"
        },
        {
            "name": "Allowed origins",
            "description": "Comma-separated HTTPS origins for Control UI when using non-loopback bind. Example: https://dsg1.stacloud.tech",
            "env_variable": "OPENCLAW_ALLOWED_ORIGINS",
            "default_value": "",
            "user_viewable": true,
            "user_editable": true,
            "rules": "nullable|string|max:500",
            "field_type": "text"
        },
        {
            "name": "Host header fallback",
            "description": "Set true to allow dangerous Host-header origin fallback when Allowed origins is empty.",
            "env_variable": "OPENCLAW_ALLOW_HOST_HEADER_ORIGIN_FALLBACK",
            "default_value": "false",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string|in:true,false",
            "field_type": "text"
