    "description": "Egg OpenClaw cho STACloud, chay OpenClaw Gateway trong Pterodactyl voi persistent state tai /home/container/.openclaw.",
    "features": null,
    "docker_images": {
        "OpenClaw Latest": "ghcr.io/sta-cloud-dev/ai:openclaw_latest"
    },
    "file_denylist": [],
    "startup": "openclaw gateway --allow-unconfigured --bind ${OPENCLAW_BIND} --port ${SERVER_PORT}",
    "config": {
        "files": "{}",
        "startup": "{\r\n    \"done\": \"listening on\"\r\n}",
        "logs": "{}",
        "stop": "^C"
    },
    "scripts": {
        "installation": {
            "script": "#!/bin/bash\r\nmkdir -p /mnt/server/.openclaw /mnt/server/.openclaw/workspace /mnt/server/.openclaw/skills\r\necho \"OpenClaw installation completed.\"",
            "container": "debian:bookworm-slim",
            "entrypoint": "bash"
        }
    },
    "variables": [
        {
            "name": "Gateway verbose",
            "description": "Enable verbose gateway logs. true = verbose, false = normal.",
            "env_variable": "OPENCLAW_VERBOSE",
            "default_value": "true",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string|in:true,false",
            "field_type": "text"
        },
        {
            "name": "Gateway bind",
            "description": "Listener bind mode for OpenClaw Gateway. Use 'lan' when behind a reverse proxy like Caddy/Nginx.",
            "env_variable": "OPENCLAW_BIND",
            "default_value": "lan",
            "user_viewable": true,
            "user_editable": true,
            "rules": "required|string|in:loopback,lan,tailnet,auto,custom",
            "field_type": "text"
        },
        {
            "name": "Custom bind host",
            "description": "Required when Gateway bind is set to 'custom'. Enter the hostname or IP to bind to.",
